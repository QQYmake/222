[project]
sub_id = "33d9cab9"
name = "vps-gateway"
entrypoint = "app/main.py"
requires = ["python-3.12"]
project_type = ""

[preview]
preview_enable = "disabled"

[deploy]
build = ["bash", "scripts/setup.sh"]
run = ["bash", "scripts/http_run.sh", "-p", "5000"]

[deploy.profile]
kind = "service"
flavor = "web"

[deploy.backend]
enabled = true
