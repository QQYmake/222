# 本地与 VPS 使用同一套代码，只替换环境配置

# --- 网关 ---
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8000
GATEWAY_API_KEY=

# --- 上游模型 (M2+) ---
UPSTREAM_BASE_URL=https://example.com
UPSTREAM_API_KEY=
UPSTREAM_MODEL=
UPSTREAM_TIMEOUT_SECONDS=30
UPSTREAM_TOKEN_LIMIT_FIELD=max_completion_tokens

# --- Sample ---
SAMPLE_DIRECTORY=./samples
MEMORY_CHAR_BUDGET=12000

# --- Outbox (M4+) ---
OUTBOX_DATABASE_PATH=./data/outbox.sqlite3

# --- 主动回合 (M5+) ---
ACTIVE_TURN_ENABLED=true
ACTIVE_TURN_INTERVAL_MINUTES=60
ACTIVE_TURN_INSTRUCTION=检查当前状态，判断是否有值得主动告诉用户的内容。

# --- 默认参数 ---
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_OUTPUT_TOKENS=1200

# --- v2 工具 ---
TOOLS_ENABLED=true
TEST_TOOLS_ENABLED=false
TOOL_MAX_ROUNDS=5
TOOL_MAX_CALLS_PER_TURN=10
TOOL_TIMEOUT_SECONDS=15
TOOL_MAX_RESULT_CHARS=12000

# --- v2 唤醒 ---
WAKE_ENABLED=true
WAKE_TIMEZONE=Asia/Shanghai
WAKE_ACTIVE_START=08:00
WAKE_ACTIVE_END=24:00
WAKE_MIN_INTERVAL_MINUTES=20
WAKE_DAILY_LIMIT=10
WAKE_SCAN_INTERVAL_SECONDS=5
WAKE_START_GRACE_SECONDS=10
WAKE_FIXED_ENABLED=true
WAKE_FIXED_INTERVAL_MINUTES=60
WAKE_RANDOM_ENABLED=false
WAKE_RANDOM_MIN_MINUTES=20
WAKE_RANDOM_MAX_MINUTES=180
WAKE_DATABASE_PATH=./data/wake_jobs.sqlite3

# --- v2 Outbox 长轮询 ---
OUTBOX_LONGPOLL_TIMEOUT_SECONDS=30
OUTBOX_READER_ID=chen-primary

# --- v3 记忆引擎 ---
MEMORY_ENABLED=false
MEMORY_DB_PATH=./data/memory.sqlite3
MEMORY_RETRIEVAL_TIMEOUT=20.0
MEMORY_SURFACE_INTERVAL=3600.0
MEMORY_CONSOLIDATION_HOUR=2

# --- v3 记忆引擎 8 模型配置 ---
MEM_EMBED_TYPE=local
MEM_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
MEM_INTENT_BASE_URL=
MEM_INTENT_API_KEY=
MEM_INTENT_MODEL=
MEM_GEN_BASE_URL=
MEM_GEN_API_KEY=
MEM_GEN_MODEL=
MEM_SURF_BASE_URL=
MEM_SURF_API_KEY=
MEM_SURF_MODEL=
MEM_EXTRACT_BASE_URL=
MEM_EXTRACT_API_KEY=
MEM_EXTRACT_MODEL=
MEM_PERSONA_BASE_URL=
MEM_PERSONA_API_KEY=
MEM_PERSONA_MODEL=
MEM_SAGA_BASE_URL=
MEM_SAGA_API_KEY=
MEM_SAGA_MODEL=
MEM_POLISH_BASE_URL=
MEM_POLISH_API_KEY=
MEM_POLISH_MODEL=
